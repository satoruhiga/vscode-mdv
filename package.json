{
  "name": "vscode-mdv",
  "displayName": "mdv - Markdown Viewer",
  "description": "Rich Markdown preview with GFM, syntax highlighting, math, and diagrams",
  "version": "0.0.11",
  "private": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "mdv-panel",
          "title": "mdv",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "mdv-panel": [
        {
          "type": "webview",
          "id": "mdv.annotationPanel",
          "name": "Annotations"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "mdv.preview",
        "displayName": "mdv Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "mdv.toggleEditor",
        "title": "Toggle Preview / Text Editor",
        "category": "mdv"
      },
      {
        "command": "mdv.reload",
        "title": "Reload Preview",
        "category": "mdv"
      },
      {
        "command": "mdv.addComment",
        "title": "Add Comment",
        "category": "mdv"
      },
      {
        "command": "mdv.copyAllAnnotations",
        "title": "Copy All Annotations",
        "category": "mdv",
        "icon": "$(copy)"
      },
      {
        "command": "mdv.clearAnnotations",
        "title": "Clear Annotations",
        "category": "mdv",
        "icon": "$(clear-all)"
      },
      {
        "command": "mdv.openPreview",
        "title": "Open with mdv",
        "category": "mdv",
        "icon": "$(open-preview)"
      },
      {
        "command": "mdv.toggleTranslate",
        "title": "Toggle Google Translate",
        "category": "mdv"
      }
    ],
    "menus": {
      "webview/context": [
        {
          "command": "mdv.addComment",
          "when": "webviewId == 'mdv.preview'",
          "group": "1_annotation"
        },
        {
          "command": "mdv.reload",
          "when": "webviewId == 'mdv.preview'",
          "group": "2_mdv@1"
        },
        {
          "command": "mdv.toggleEditor",
          "when": "webviewId == 'mdv.preview'",
          "group": "2_mdv@2"
        },
        {
          "command": "mdv.toggleTranslate",
          "when": "webviewId == 'mdv.preview'",
          "group": "2_mdv@3"
        }
      ],
      "explorer/context": [
        {
          "command": "mdv.openPreview",
          "when": "resourceExtname == '.md'",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "mdv.copyAllAnnotations",
          "when": "view == 'mdv.annotationPanel'",
          "group": "navigation"
        },
        {
          "command": "mdv.clearAnnotations",
          "when": "view == 'mdv.annotationPanel'",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mdv.toggleEditor",
        "key": "ctrl+shift+v",
        "when": "activeCustomEditorId == 'mdv.preview' || resourceExtname == '.md'"
      }
    ],
    "configuration": {
      "title": "mdv",
      "properties": {
        "mdv.fontSize": {
          "type": "number",
          "default": 16,
          "description": "Base font size in pixels for the preview"
        },
        "mdv.fontFamily": {
          "type": "string",
          "default": "Cascadia, Consolas, monospace",
          "description": "Font family for the preview"
        },
        "mdv.googleTranslate.targetLanguage": {
          "type": "string",
          "default": "ja",
          "description": "Target language code for Google Translate (e.g. ja, en, zh-CN)"
        },
        "mdv.googleTranslate.pageLanguage": {
          "type": "string",
          "default": "auto",
          "description": "Source page language code for Google Translate (use 'auto' to detect)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@flowershow/remark-wiki-link": "^3.3.1",
    "@shikijs/rehype": "^3.20.0",
    "katex": "^0.16.27",
    "mermaid": "^11.12.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-deflist": "^1.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mark-highlight": "^0.1.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-supersub": "^1.0.0",
    "shiki": "^3.20.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.2"
  }
}
